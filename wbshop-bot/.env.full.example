## Full configuration reference (optional)
##
## This file lists ALL environment variables supported by the project.
## For a public repo, prefer keeping `wbshop-bot/.env.example` minimal.

## ===============================
## Minimal required (to run bot)
## ===============================
BOT_TOKEN=

## ===============================
## Branding / links (demo-safe)
## ===============================
BRAND_NAME=Example Brand
BRAND_TAG=EXAMPLE
BOT_FALLBACK_USERNAME=ExampleBrandBot

BRAND_SITE_URL=https://example.com
COMMUNITY_URL=https://t.me/example_brand

CATALOG_WB_URL=https://example.com/catalog/wildberries
CATALOG_OZON_URL=https://example.com/catalog/ozon
CATALOG_YM_URL=https://example.com/catalog/yandex-market

PARTNER_FORM_URL=https://example.com/partner-form

## ===============================
## Database (optional)
## ===============================
DATABASE_URL=sqlite+aiosqlite:///app.db

## ===============================
## Support forum (optional)
## ===============================
SUPPORT_GROUP_ID=0
GENERAL_THREAD_ID=0
AUTOCLOSE_HOURS=48
TICKET_TTL_MINUTES=45
# Legacy/compat:
# PROJECT_TAG=EXAMPLE

## ===============================
## Notifications (optional)
## ===============================
NOTIFY_SOURCE_CHANNEL=@example_brand_news

## ===============================
## Wildberries API (optional)
## ===============================
WB_API_KEY=
WB_STAT_BASE=https://statistics-api.wildberries.ru
# Alternative token sources (wb_api.py)
# WB_API_TOKEN=
# WB_API_TOKENS_JSON=

## ===============================
## Cashback flow / Google Sheets (optional)
## ===============================
GSHEETS_SPREADSHEET_ID=
GSHEETS_SHEET_NAME=Applications
GSHEETS_CREDENTIALS_B64=
GSHEETS_CREDENTIALS_JSON=
PROJECT_ROOT=

## Cashback tuning (bonus.py)
BONUS_LOG_LEVEL=INFO
BONUS_ORDER_MAX_AGE_DAYS=0
BONUS_MAX_SRIDS=0
BONUS_MIN_GOOD_RATING=5

## HOWTO video (bonus.py + scripts/upload_howto_video.py)
HOWTO_VIDEO_FILE_ID=
HOWTO_VIDEO_PATH=instruction.mp4
HOWTO_VIDEO_CACHE_JSON=data/howto_video.json
HOWTO_VIDEO_ADMIN_USERNAME=
# Only for upload script:
# HOWTO_VIDEO_TARGET_CHAT_ID=
# HOWTO_VIDEO_THREAD_ID=
# HOWTO_VIDEO_ADMIN_ID=

## ===============================
## Agents tuning (optional)
## ===============================
WB_REVIEWS_LOOKBACK_DAYS=90
WB_FEEDBACK_TAKE=5000
WB_FEEDBACK_CHUNK_DAYS=1
REVIEWS_TABLE_NAME=reviews
REVIEWS_DATE_COLUMN=created_at
REVIEWS_MONTHS_TO_KEEP=9

## ===============================
## Local encryption (optional)
## ===============================
TOKENS_FERNET_KEY=
